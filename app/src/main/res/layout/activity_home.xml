<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app_res="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="80dp"
            app_res:cardBackgroundColor="@color/blue_primary"
            app_res:cardCornerRadius="50dp"
            app_res:cardElevation="4dp"
            app_res:layout_constraintEnd_toEndOf="parent"
            app_res:layout_constraintStart_toStartOf="parent"
            app_res:layout_constraintTop_toTopOf="parent"
            app_res:strokeWidth="0dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                android:tint="@color/white"
                tools:ignore="UseAppTint" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvWelcomeHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Welcome!"
            android:textColor="@color/black"
            android:textSize="32sp"
            android:textStyle="bold"
            app_res:layout_constraintEnd_toEndOf="parent"
            app_res:layout_constraintStart_toStartOf="parent"
            app_res:layout_constraintTop_toBottomOf="@id/cardProfile" />

        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="user@example.com"
            android:textColor="@color/gray_secondary"
            android:textSize="16sp"
            android:textStyle="bold"
            app_res:layout_constraintEnd_toEndOf="parent"
            app_res:layout_constraintStart_toStartOf="parent"
            app_res:layout_constraintTop_toBottomOf="@id/tvWelcomeHome" />

        <TextView
            android:id="@+id/tvProviderInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Logged in via: firebase"
            android:textColor="@color/gray_secondary"
            android:alpha="0.6"
            android:textSize="14sp"
            app_res:layout_constraintEnd_toEndOf="parent"
            app_res:layout_constraintStart_toStartOf="parent"
            app_res:layout_constraintTop_toBottomOf="@id/tvUserEmail" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app_res:cardBackgroundColor="@color/blue_primary"
            app_res:cardCornerRadius="12dp"
            app_res:cardElevation="2dp"
            app_res:layout_constraintBottom_toBottomOf="parent"
            app_res:strokeWidth="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Log Out"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
