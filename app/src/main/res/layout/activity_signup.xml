<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app_res="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app_res:cardBackgroundColor="@color/white"
        app_res:cardCornerRadius="20dp"
        app_res:cardElevation="1dp"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintTop_toTopOf="parent"
        app_res:strokeWidth="0dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_back"
            android:tint="@color/black"
            tools:ignore="UseAppTint" />
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!-- Header Section -->
            <ImageView
                android:id="@+id/ivSignupHeader"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="100dp"
                android:src="@drawable/ic_person"
                android:tint="@color/blue_primary"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toTopOf="parent"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/tvCreateAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Create Account"
                android:textColor="@color/black"
                android:textSize="28sp"
                android:textStyle="bold"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/ivSignupHeader" />

            <TextView
                android:id="@+id/tvSignupSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sign up to get started"
                android:textColor="@color/gray_secondary"
                android:textSize="14sp"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/tvCreateAccount" />

            <!-- Input Fields -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEmail"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="24dp"
                app_res:cardBackgroundColor="@color/white"
                app_res:cardCornerRadius="12dp"
                app_res:cardElevation="2dp"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/tvSignupSubtitle"
                app_res:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        android:tint="@color/gray_secondary"
                        tools:ignore="UseAppTint" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPassword"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                app_res:cardBackgroundColor="@color/white"
                app_res:cardCornerRadius="12dp"
                app_res:cardElevation="2dp"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/cardEmail"
                app_res:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/gray_secondary"
                        tools:ignore="UseAppTint" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivPasswordToggle"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_visibility"
                        android:tint="@color/gray_secondary"
                        tools:ignore="UseAppTint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                app_res:cardBackgroundColor="@color/white"
                app_res:cardCornerRadius="12dp"
                app_res:cardElevation="2dp"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/cardPassword"
                app_res:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/gray_secondary"
                        tools:ignore="UseAppTint" />

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Confirm Password"
                        android:inputType="textPassword"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivConfirmPasswordToggle"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_visibility"
                        android:tint="@color/gray_secondary"
                        tools:ignore="UseAppTint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvError"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:textColor="@color/red_error"
                android:textSize="13sp"
                android:visibility="gone"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/cardConfirmPassword" />

            <!-- Signup Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSignUp"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app_res:cardBackgroundColor="@color/blue_primary"
                app_res:cardCornerRadius="12dp"
                app_res:cardElevation="2dp"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/tvError"
                app_res:strokeWidth="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Sign Up"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Login Link -->
            <LinearLayout
                android:id="@+id/llLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app_res:layout_constraintEnd_toEndOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintTop_toBottomOf="@id/btnSignUp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account?"
                    android:textColor="@color/gray_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnNavigateToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:padding="8dp"
                    android:text="Log In"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
